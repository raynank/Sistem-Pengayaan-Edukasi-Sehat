{
  "manifest_version": 3,
  "name": "NoPMO Web Filter",
  "version": "1.0.0",
  "description": "Block negative content and sync with NoPMO Tracker.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NoPMO Status"
  }
}
