{
  "manifest_version": 3,
  "name": "Internet Sehat Web Filter",
  "version": "1.0.0",
  "description": "Blokir konten negatif dan pantau progresmu.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Internet Sehat Status"
  }
}
