# Salin file ini menjadi .env dan isi dengan nilai yang sebenarnya
# cp .env.example .env

# Secret key Flask — gunakan string acak minimal 64 karakter
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti_dengan_random_secret_key_minimal_64_karakter

# URL koneksi PostgreSQL di vm-database (192.168.1.10)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://nopmo_user:ganti_dengan_password_db@192.168.1.10:5432/nopmo_db

# Catatan: Saat production, ganti host 192.168.1.10 dengan IP vm-database aktual
